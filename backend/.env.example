# Archivo de ejemplo para variables de entorno
# Copiar a .env y completar con tus valores. NUNCA commitear el .env real.

# --- Base de datos ---
DATABASE_URL=postgresql://user:password@localhost:5432/turno_ia_dev

# --- JWT (S1) ---
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=cambiame_por_un_secreto_largo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Twilio (se usa en S2) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
